{
  "name": "zythohunt",
  "version": "0.4.5",
  "private": true,
  "type": "module",
  "scripts": {
    "build:taxonomy": "node scripts/build-taxonomy.mjs",
    "build:layout": "node scripts/build-layout.mjs",
    "validate:taxonomy": "node scripts/validate-taxonomy.mjs --taxonomy-only",
    "validate:layout": "node scripts/validate-layout.mjs",
    "validate": "npm run build:taxonomy && npm run build:layout && npm run validate:taxonomy && npm run validate:icons && npm run validate:layout",
    "validate:icons": "node scripts/validate-icons.mjs",
    "validate:determinism": "node scripts/validate-determinism.mjs",
    "report:layout": "node scripts/layout/layout-report.mjs"
  },
  "devDependencies": {
    "d3-force": "file:vendor/d3-force",
    "d3-hierarchy": "file:vendor/d3-hierarchy",
    "d3-shape": "file:vendor/d3-shape"
  }
}
